rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // المستخدم العادي — معاملاته
    match /users/{userId}/transactions/{txnId} {
      allow read, write: if request.auth != null 
                         && request.auth.uid == userId;
    }

    // كل مستخدم يكتب بروفايله
    match /users/{userId} {
      allow write: if request.auth != null 
                   && request.auth.uid == userId;
      allow read: if request.auth != null
                  && (request.auth.uid == userId 
                      || request.auth.token.email == 'shady.nasif@gmail.com');
    }

    // الأدمن — يقرأ كل المعاملات
    match /{path=**}/transactions/{txnId} {
      allow read, delete: if request.auth != null 
                          && request.auth.token.email == 'shady.nasif@gmail.com';
    }

    // منع أي وصول لأي مسار آخر
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
